# ── App Runner 環境変数 ──────────────────────────────────────────
NODE_ENV=development

# AWS リージョン
AWS_REGION=ap-northeast-1

# RDS Proxy エンドポイント（VPC 内・プライベート）
RDS_PROXY_ENDPOINT=your-proxy.proxy-xxxx.ap-northeast-1.rds.amazonaws.com

# DB 設定（パスワード不要。IAM 認証トークンを使用）
DB_USER=vitanota_app
DB_NAME=vitanota

# Auth.js コールバック URL
NEXTAUTH_URL=http://localhost:3000

# ── Secrets Manager 管理シークレット（ローカル開発時のみ直接設定）──
# 本番では App Runner の Secrets Manager 参照を使用する
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── ローカル開発用（Secrets Manager を使わない場合）──
# SKIP_SECRETS_MANAGER=true
