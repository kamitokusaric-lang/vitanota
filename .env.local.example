# ローカル開発用環境変数テンプレート
# コピーして使う: cp .env.local.example .env.local
# ⚠️ .env.local は git にコミットしないこと (.gitignore で除外済み)

# ── データベース ───────────────────────────────────────────────
# Docker Compose の PostgreSQL に接続
DATABASE_URL=postgresql://vitanota:vitanota_local@localhost:5432/vitanota_dev

# db.ts が参照する個別変数 (DATABASE_URL と重複だが既存コード互換のため)
RDS_PROXY_ENDPOINT=localhost
DB_USER=vitanota
DB_NAME=vitanota_dev
DB_PASSWORD=vitanota_local

# ── Next.js / Auth.js ─────────────────────────────────────────
NODE_ENV=development
NEXTAUTH_URL=http://localhost:3000
# ローカル用ダミーシークレット (本番は Secrets Manager から取得)
NEXTAUTH_SECRET=local-dev-secret-minimum-32-bytes-please-use-longer

# ── E2E テストモード ──────────────────────────────────────────
# true にすると /api/test/_seed エンドポイントが有効になる
# ローカル開発中はログインバイパスに使える
E2E_TEST_MODE=true

# ── Google OAuth (任意・E2E_TEST_MODE=true なら不要) ──────────
# ローカルでは test seed API でセッション作成できるので未設定で OK
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── ログレベル ─────────────────────────────────────────────────
LOG_LEVEL=debug
