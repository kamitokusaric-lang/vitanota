{
  "name": "vitanota",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "rls:generate": "tsx src/db/rls/cli.ts generate",
    "rls:check": "tsx src/db/rls/cli.ts check",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:local:up": "docker compose up -d",
    "db:local:down": "docker compose down",
    "db:local:reset": "docker compose down -v && docker compose up -d",
    "db:local:migrate": "./scripts/local/migrate.sh",
    "db:local:seed": "./scripts/local/seed.sh",
    "gen:openapi": "tsx scripts/gen-openapi.ts",
    "openapi:check": "pnpm gen:openapi && git diff --exit-code openapi.yaml"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@aws-sdk/client-secrets-manager": "^3.574.0",
    "@aws-sdk/rds-signer": "^3.574.0",
    "@hookform/resolvers": "^5.2.2",
    "drizzle-orm": "^0.30.10",
    "next": "^14.2.0",
    "next-auth": "^4.24.7",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-http": "^10.2.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-hook-form": "^7.72.1",
    "swr": "^2.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^7.3.4",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.4.2",
    "@testing-library/react": "^15.0.6",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^20.12.0",
    "@types/pg": "^8.11.6",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/coverage-v8": "^1.5.0",
    "autoprefixer": "^10.4.19",
    "drizzle-kit": "^0.21.2",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "jsdom": "^24.0.0",
    "postcss": "^8.4.38",
    "tailwindcss": "^3.4.3",
    "tsx": "^4.21.0",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0",
    "yaml": "^2.8.3"
  }
}
